---
// The Diving Diaries wordmark — bold display text inside a stadium outline,
// echoing the logo. `variant` controls colour for light vs dark backgrounds.
interface Props {
  variant?: 'light' | 'dark';
  size?: 'sm' | 'md' | 'lg';
  href?: string | null;
  class?: string;
}
const { variant = 'dark', size = 'md', href = '/', class: klass = '' } = Astro.props;

const color = variant === 'light' ? 'text-white border-white' : 'text-ocean-800 border-ocean-800';
const sizing = {
  sm: 'text-base px-3 py-1 border-2',
  md: 'text-xl px-4 py-1.5 border-[3px]',
  lg: 'text-3xl px-6 py-2 border-4',
}[size];

const Tag = href ? 'a' : 'span';
---

<Tag
  {...href ? { href } : {}}
  class={`wordmark inline-flex items-center rounded-full font-black leading-none tracking-tight ${color} ${sizing} ${klass}`}
  aria-label="Diving Diaries"
>
  DIVINGDIARIES
</Tag>
