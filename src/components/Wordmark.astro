---
import { Image } from 'astro:assets';
import longWhite from '../assets/logo/logo-long-white.png';
import longDark from '../assets/logo/logo-long-dark.png';
import shortWhite from '../assets/logo/logo-short-white.png';
import shortDark from '../assets/logo/logo-short-dark.png';

// Diving Diaries logo.
//  type: 'long'  → full DIVINGDIARIES wordmark (primary lockup)
//        'short' → compact D·DIARIES mark (watermark / tight spaces)
//  variant: 'light' (for dark backgrounds) | 'dark' (for light backgrounds)
interface Props {
  type?: 'long' | 'short';
  variant?: 'light' | 'dark';
  size?: 'sm' | 'md' | 'lg';
  href?: string | null;
  class?: string;
}
const { type = 'long', variant = 'light', size = 'md', href = '/', class: klass = '' } = Astro.props;

const img =
  type === 'long'
    ? variant === 'light'
      ? longWhite
      : longDark
    : variant === 'light'
      ? shortWhite
      : shortDark;

const heights = { sm: 30, md: 44, lg: 88 };
const h = heights[size];
const Tag = href ? 'a' : 'div';
---

<Tag {...href ? { href } : {}} class={`inline-flex items-center ${klass}`} aria-label="Diving Diaries">
  <Image src={img} alt="Diving Diaries" height={h} width={Math.round((img.width / img.height) * h)} densities={[1, 2]} loading="eager" />
</Tag>
