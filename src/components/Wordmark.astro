---
import { Image } from 'astro:assets';
import white from '../assets/logo/wordmark-white.png';
import dark from '../assets/logo/wordmark-dark.png';

// The Diving Diaries logo (D·DIARIES mark). `variant` picks white (for dark
// backgrounds) or dark (for light backgrounds).
interface Props {
  variant?: 'light' | 'dark';
  size?: 'sm' | 'md' | 'lg';
  href?: string | null;
  class?: string;
}
const { variant = 'light', size = 'md', href = '/', class: klass = '' } = Astro.props;

const img = variant === 'light' ? white : dark;
const heights = { sm: 28, md: 40, lg: 96 };
const h = heights[size];

const Tag = href ? 'a' : 'div';
---

<Tag {...href ? { href } : {}} class={`inline-flex items-center ${klass}`} aria-label="Diving Diaries">
  <Image src={img} alt="Diving Diaries" height={h} width={Math.round((img.width / img.height) * h)} densities={[1, 2]} loading="eager" />
</Tag>
