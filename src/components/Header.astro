---
import Wordmark from './Wordmark.astro';
import { NAV } from '../lib/nav';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="fixed inset-x-0 top-0 z-50 px-4 pt-4">
  <nav
    id="site-nav"
    class="mx-auto flex max-w-5xl items-center justify-between rounded-full border border-white/15 bg-ocean-950/45 py-2.5 pl-5 pr-3 shadow-xl backdrop-blur-xl transition-all duration-300"
  >
    <Wordmark variant="light" size="sm" href="/" />

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 md:flex">
      {
        NAV.filter((n) => n.href !== '/').map((n) => (
          <li>
            <a
              href={n.href}
              class:list={[
                'rounded-full px-4 py-2 text-sm font-semibold uppercase tracking-wide transition-colors',
                isActive(n.href)
                  ? 'bg-purple-500 text-white'
                  : 'text-white/85 hover:bg-white/10 hover:text-white',
              ]}
            >
              {n.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile nav -->
    <details class="relative md:hidden">
      <summary class="flex cursor-pointer list-none items-center rounded-full p-2 text-white">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </summary>
      <ul class="absolute right-0 mt-3 w-52 rounded-2xl border border-white/10 bg-ocean-950/90 p-2 shadow-xl backdrop-blur-xl">
        {
          NAV.map((n) => (
            <li>
              <a
                href={n.href}
                class:list={[
                  'block rounded-xl px-4 py-2.5 text-sm font-semibold uppercase tracking-wide',
                  isActive(n.href) ? 'bg-purple-500 text-white' : 'text-white/85 hover:bg-white/10',
                ]}
              >
                {n.label}
              </a>
            </li>
          ))
        }
      </ul>
    </details>
  </nav>
</header>

<script>
  // Subtle solidify on scroll for legibility over light content.
  const nav = document.getElementById('site-nav');
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 40) nav.classList.add('bg-ocean-950/85');
    else nav.classList.remove('bg-ocean-950/85');
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
