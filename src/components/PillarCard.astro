---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
interface Props {
  slug: string;
  label: string;
  blurb: string;
  index: number;
  image?: ImageMetadata;
}
const { slug, label, blurb, index, image } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<a
  href={`/pillars/${slug}`}
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-ocean-100 bg-white transition-all hover:-translate-y-1 hover:border-ocean-300 hover:shadow-xl"
>
  <div class="relative aspect-[4/3] overflow-hidden bg-ocean-900">
    {
      image && (
        <Image
          src={image}
          alt={label}
          widths={[400, 640, 800]}
          sizes="(max-width: 640px) 100vw, 400px"
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      )
    }
    <div class="absolute inset-0 bg-gradient-to-t from-ocean-950/80 via-ocean-950/10 to-transparent"></div>
    <span class="wordmark absolute left-4 top-3 text-sm font-black text-white/70">{num}</span>
    <h3 class="absolute bottom-3 left-4 text-2xl text-white drop-shadow">{label}</h3>
  </div>
  <div class="flex flex-1 flex-col p-5">
    <p class="flex-1 text-sm leading-relaxed text-slate-600">{blurb}</p>
    <span class="mt-4 text-sm font-bold uppercase tracking-wide text-ocean-600">
      Explore →
    </span>
  </div>
</a>
