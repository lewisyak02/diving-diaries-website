---
interface Props {
  slug: string;
  label: string;
  blurb: string;
  index: number;
}
const { slug, label, blurb, index } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<a
  href={`/pillars/${slug}`}
  class="group relative flex flex-col rounded-2xl border border-ocean-100 bg-white p-6 transition-all hover:-translate-y-1 hover:border-ocean-300 hover:shadow-lg"
>
  <span class="wordmark text-sm font-black text-ocean-300 group-hover:text-ocean-500">{num}</span>
  <h3 class="mt-2 text-xl text-ocean-800">{label}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{blurb}</p>
  <span class="mt-4 text-sm font-bold uppercase tracking-wide text-ocean-600">
    Explore →
  </span>
</a>
