---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import PillarCard from '../components/PillarCard.astro';
import PostCard from '../components/PostCard.astro';
import { PILLARS } from '../lib/nav';
import { SITE } from '../lib/site';
import { pillarImages } from '../lib/pillarImages';
import freediver from '../assets/freediver.jpg';
import encounterData from '../content/encounters/index.json';

const posts = (await getCollection('journal', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const encounters = encounterData.items;
---

<Layout>
  <!-- Video hero -->
  <section class="relative flex min-h-[100svh] items-center justify-center overflow-hidden bg-ocean-950">
    <video
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/hero/hawksbill-poster.jpg"
    >
      <source src="/hero/hawksbill.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-ocean-950/55 via-ocean-950/20 to-ocean-950/80"></div>

    <div class="relative mx-auto max-w-3xl px-5 text-center text-white">
      <h1 class="mx-auto max-w-3xl text-5xl leading-[0.82] tracking-[-0.04em] drop-shadow-[0_2px_18px_rgba(1,18,58,0.6)] sm:text-6xl md:text-7xl">
        {SITE.catchphrase}
      </h1>
      <p class="mx-auto mt-3 max-w-xl text-lg text-white/90 drop-shadow-[0_1px_10px_rgba(1,18,58,0.7)]">
        A home for underwater adventures, dive stories, and honest gear reviews and tips.
      </p>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-4">
        <Button href="/watch" variant="primary">Watch the dives</Button>
        <Button href="/journal" variant="outline" class="border-white text-white hover:bg-white hover:text-ocean-900">Read the journal</Button>
      </div>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/60">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-bounce">
        <path d="M12 5v14M19 12l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- Credentials strip -->
  <section class="border-b border-ocean-100 bg-white">
    <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-10 gap-y-3 px-5 py-6 text-center text-sm font-semibold uppercase tracking-widest text-ocean-700">
      <span>Diving all around Australia</span>
      <span class="hidden text-purple-300 sm:inline">/</span>
      <span>Shot on DJI Osmo Action 5 Pro</span>
      <span class="hidden text-purple-300 sm:inline">/</span>
      <span>PADI Divemaster</span>
    </div>
  </section>

  <!-- Intro -->
  <section class="mx-auto max-w-3xl px-5 py-20 text-center">
    <p class="kicker">The brand</p>
    <h2 class="mt-3 text-3xl text-ocean-800 sm:text-4xl">Bringing the ocean to the surface</h2>
    <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-slate-600">
      Diving Diaries documents real dives, real marine life, and my journey through
      the sport. It started as a way to share my passion for diving with the world,
      and to bring the underwater world to people who may never see it in person.
    </p>
    <div class="mt-7">
      <Button href="/about" variant="outline">More about the brand</Button>
    </div>
  </section>

  <!-- Pillars -->
  <section class="bg-sand-50 py-20">
    <div class="mx-auto max-w-6xl px-5">
      <div class="text-center">
        <p class="kicker">What we create</p>
        <h2 class="mt-3 text-3xl text-ocean-800 sm:text-4xl">Five pillars, one ocean</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {PILLARS.map((p, i) => <PillarCard slug={p.slug} label={p.label} blurb={p.blurb} index={i} image={pillarImages[p.slug]} />)}
      </div>
    </div>
  </section>

  <!-- Encounters gallery -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="text-center">
      <p class="kicker">From the deep</p>
      <h2 class="mt-3 text-3xl text-ocean-800 sm:text-4xl">Recent encounters</h2>
    </div>
    <div class="mt-10 grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
      {
        encounters.map((e) => (
          <figure class="group relative aspect-square overflow-hidden rounded-2xl bg-ocean-900">
            <img
              src={e.image}
              alt={e.caption}
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-purple-900/70 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
            <figcaption class="absolute bottom-3 left-4 text-sm font-bold uppercase tracking-wide text-white opacity-0 transition-opacity group-hover:opacity-100">
              {e.caption}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <!-- Mission band (cinematic) -->
  <section class="relative overflow-hidden">
    <Image
      src={freediver}
      alt="A freediver ascending toward the light"
      class="absolute inset-0 h-full w-full object-cover"
      widths={[768, 1280, 1920]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-ocean-950/85 via-ocean-950/70 to-purple-900/75"></div>
    <div class="relative mx-auto max-w-3xl px-5 py-28 text-center text-white">
      <p class="text-2xl font-medium leading-snug sm:text-3xl">
        “I just want to share my passion for diving with the world.”
      </p>
      <p class="kicker mt-6 text-purple-200">My mission</p>
    </div>
  </section>

  <!-- Latest journal -->
  {
    posts.length > 0 && (
      <section class="mx-auto max-w-6xl px-5 py-20">
        <div class="flex items-end justify-between">
          <div>
            <p class="kicker">Field notes</p>
            <h2 class="mt-3 text-3xl text-ocean-800 sm:text-4xl">From the journal</h2>
          </div>
          <a href="/journal" class="text-sm font-bold uppercase tracking-wide text-purple-600 hover:text-purple-700">
            All posts →
          </a>
        </div>
        <div class="mt-8 grid gap-6 md:grid-cols-3">
          {posts.map((p) => (
            <PostCard
              slug={p.id}
              title={p.data.title}
              date={p.data.date}
              pillar={p.data.pillar}
              excerpt={p.data.excerpt}
              cover={p.data.cover}
            />
          ))}
        </div>
      </section>
    )
  }

  <!-- Watch CTA -->
  <section class="relative overflow-hidden bg-ocean-900">
    <div class="absolute inset-0 bg-gradient-to-r from-ocean-900 to-purple-900/60"></div>
    <div class="relative mx-auto flex max-w-4xl flex-col items-center px-5 py-20 text-center text-white">
      <h2 class="text-3xl sm:text-4xl">New underwater adventures every week</h2>
      <p class="mt-4 max-w-xl text-ocean-100">
        Subscribe on YouTube and follow along as we explore the beauty of the
        underwater world, one dive at a time.
      </p>
      <div class="mt-8">
        <Button href={SITE.socials.youtube} variant="light" external>Subscribe on YouTube</Button>
      </div>
    </div>
  </section>
</Layout>
