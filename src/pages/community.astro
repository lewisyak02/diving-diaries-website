---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { SITE } from '../lib/site';
import community from '../content/community/index.json';

const yt = community.youtube ?? { subscribers: 0, views: 0 };
const ig = community.instagram ?? { followers: 0 };
const tt = community.tiktok ?? { followers: 0 };

const totalFollowers = (yt.subscribers || 0) + (ig.followers || 0) + (tt.followers || 0);
const totalViews = yt.views || 0;
const comma = (n: number) => (n || 0).toLocaleString('en-AU');

const platforms = [
  { name: 'YouTube', metric: 'subscribers', value: yt.subscribers, note: `${comma(yt.views || 0)} total views`, href: SITE.socials.youtube },
  { name: 'Instagram', metric: 'followers', value: ig.followers, note: null, href: SITE.socials.instagram },
  { name: 'TikTok', metric: 'followers', value: tt.followers, note: null, href: SITE.socials.tiktok },
].filter((p) => p.href);

const updated = community.updated
  ? new Date(community.updated).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;
---

<Layout
  title="Community"
  description="The Diving Diaries community across YouTube, Instagram, and TikTok. Follow along and help grow the channel."
>
  <!-- Totals -->
  <section class="relative overflow-hidden bg-ocean-900 text-white">
    <div class="absolute inset-0 bg-gradient-to-br from-ocean-900 via-ocean-950 to-purple-900/70"></div>
    <div class="relative mx-auto max-w-5xl px-5 pb-16 pt-32 text-center">
      <p class="kicker text-purple-200">The community</p>
      <h1 class="mt-3 text-4xl sm:text-6xl">Growing together</h1>
      <div class="mt-12 grid gap-8 sm:grid-cols-2">
        <div>
          <div class="text-5xl sm:text-7xl">{comma(totalFollowers)}</div>
          <p class="mt-2 text-sm font-bold uppercase tracking-widest text-purple-200">Followers across platforms</p>
        </div>
        <div>
          <div class="text-5xl sm:text-7xl">{comma(totalViews)}</div>
          <p class="mt-2 text-sm font-bold uppercase tracking-widest text-purple-200">Total video views</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Per platform -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="grid gap-6 sm:grid-cols-3">
      {
        platforms.map((p) => (
          <div class="flex flex-col rounded-2xl border border-ocean-100 bg-white p-8 text-center transition-all hover:-translate-y-1 hover:shadow-lg">
            <div class="text-4xl text-ocean-800">{comma(p.value || 0)}</div>
            <p class="mt-1 text-sm font-bold uppercase tracking-widest text-purple-500">{p.name}</p>
            <p class="mt-1 text-xs uppercase tracking-wide text-slate-500">{p.metric}</p>
            {p.note && <p class="mt-3 text-sm text-slate-500">{p.note}</p>}
            <div class="mt-6">
              <Button href={p.href} variant="outline" external>Follow</Button>
            </div>
          </div>
        ))
      }
    </div>

    {updated && <p class="mt-10 text-center text-xs uppercase tracking-widest text-slate-400">Numbers updated {updated}</p>}

    <div class="mt-14 rounded-2xl bg-sand-50 p-10 text-center">
      <h2 class="text-2xl text-ocean-800">Be part of the dive</h2>
      <p class="mx-auto mt-3 max-w-xl text-slate-600">
        Every subscribe, follow, and comment helps bring more of the underwater
        world to the surface. Come along for the ride.
      </p>
      <div class="mt-6">
        <Button href={SITE.socials.youtube} variant="primary" external>Subscribe on YouTube</Button>
      </div>
    </div>
  </section>
</Layout>
