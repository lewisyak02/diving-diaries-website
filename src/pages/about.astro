---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { SITE } from '../lib/site';
import diver from '../assets/diver.jpg';

const sections = [
  {
    heading: 'Who we are',
    body: `Diving Diaries is an underwater adventure content brand sharing the ocean with audiences across social media. Through cinematic videos, photography, and storytelling on YouTube, Instagram, and TikTok, we document real dives, real marine life encounters, and the journey of a diver progressing through the sport, capturing the beauty of the underwater world and bringing it to people who may never see it in person. Home water is the Gold Coast, and the dives range all around Australia.`,
  },
  {
    heading: 'How we make it',
    body: `Every piece of Diving Diaries content is shot, edited, and published in house. Footage is captured on a DJI Osmo Action 5 Pro, then graded with a custom underwater preset and LUT workflow that restores the colour the ocean hides at depth, giving the brand its signature vibrant, true to life look. Paired with carefully chosen ambient soundtracks, the result is content designed to feel the way diving feels: calm, immersive, and full of wonder.`,
  },
  {
    heading: 'Behind the mask',
    body: `Diving Diaries is built on real diving credentials, not just a camera. The diver behind the brand is a qualified PADI Divemaster, a professional level certification that includes first aid and CPR, advanced resuscitation, dive site mapping, emergency assistance planning, and formal risk assessment. That training shapes the content: everything we share is grounded in safe, responsible diving practice.`,
  },
  {
    heading: 'Our mission',
    body: `To make the underwater world visible. We believe people protect what they love, and love what they've seen, so we bring the reefs, wrecks, and wildlife of our oceans to every screen we can reach, and inspire the next generation of divers to take their first breath underwater.`,
  },
];
---

<Layout
  title="About"
  description="Diving Diaries is an underwater adventure content brand from a PADI Divemaster diving all around Australia, built on real diving credentials and a mission to make the underwater world visible."
>
  <!-- Hero -->
  <section class="relative flex min-h-[60vh] items-center overflow-hidden">
    <Image
      src={diver}
      alt="The diver behind Diving Diaries underwater at a Gold Coast dive site"
      class="absolute inset-0 h-full w-full object-cover"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-ocean-950/80 to-ocean-900/40"></div>
    <div class="relative mx-auto w-full max-w-6xl px-5 text-white">
      <h1 class="text-4xl sm:text-6xl">About Diving Diaries</h1>
      <p class="mt-4 max-w-xl text-lg text-ocean-100">{SITE.tagline}</p>
    </div>
  </section>

  <!-- Story -->
  <section class="mx-auto max-w-3xl px-5 py-20">
    <div class="space-y-14">
      {
        sections.map((s) => (
          <div>
            <h2 class="text-2xl text-ocean-800">{s.heading}</h2>
            <p class="mt-4 text-lg leading-relaxed text-slate-600">{s.body}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-16 flex flex-wrap gap-4 border-t border-ocean-100 pt-10">
      <Button href="/watch">Watch the dives</Button>
      <Button href="/contact" variant="outline">Get in touch</Button>
    </div>
  </section>
</Layout>
