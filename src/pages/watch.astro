---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import VideoGrid from '../components/VideoGrid.astro';
import { socialLinks } from '../lib/site';
import videoData from '../content/videos/index.json';
import watchBg from '../assets/watch-bg.jpg';

const videos = videoData.items ?? [];
---

<Layout
  title="Watch"
  description="Watch Diving Diaries, cinematic dive trips, marine life encounters, and the Fish ID series. New underwater adventures every week on YouTube."
>
  <!-- Hero -->
  <section class="relative flex min-h-[60vh] items-center overflow-hidden">
    <Image
      src={watchBg}
      alt="Underwater diver with light rays"
      class="absolute inset-0 h-full w-full object-cover"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-ocean-950/85 via-ocean-950/60 to-purple-900/70"></div>
    <div class="relative mx-auto w-full max-w-3xl px-5 pt-20 text-center text-white">
      <p class="kicker text-purple-200">The channel</p>
      <h1 class="mt-3 text-4xl sm:text-6xl">Watch</h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-ocean-100">
        Every long form dive, in one place. New underwater adventures every week:
        diary entries, dive site reviews, fish ID, gear and tips.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        {
          socialLinks.map((s, i) =>
            i === 0 ? (
              <Button href={s.href} variant="light" external>{s.label}</Button>
            ) : (
              <Button href={s.href} variant="outline" external class="border-white text-white hover:bg-white hover:text-ocean-900">{s.label}</Button>
            )
          )
        }
      </div>
    </div>
  </section>

  <!-- Video grid -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <div class="mb-10 text-center">
      <p class="kicker">Long form dives</p>
      <h2 class="mt-3 text-3xl text-ocean-800 sm:text-4xl">The dive log</h2>
      <p class="mx-auto mt-3 max-w-xl text-slate-600">
        {videos.length} episodes and counting. Tap any thumbnail to play.
      </p>
    </div>
    {
      videos.length > 0 ? (
        <VideoGrid videos={videos} />
      ) : (
        <p class="text-center text-slate-600">Videos are on the way.</p>
      )
    }
  </section>
</Layout>
