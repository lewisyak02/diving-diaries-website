---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { PILLARS } from '../lib/nav';
import { socialLinks } from '../lib/site';
import watchBg from '../assets/watch-bg.jpg';
---

<Layout
  title="Watch"
  description="Watch Diving Diaries — cinematic dive trips, marine life encounters, and the Fish ID series. New underwater adventures every week on YouTube."
>
  <!-- Hero -->
  <section class="relative flex min-h-[55vh] items-center overflow-hidden">
    <Image
      src={watchBg}
      alt="Underwater diver with light rays"
      class="absolute inset-0 h-full w-full object-cover"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-ocean-950/70"></div>
    <div class="relative mx-auto w-full max-w-3xl px-5 text-center text-white">
      <h1 class="text-4xl sm:text-6xl">Watch</h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-ocean-100">
        New underwater adventures every week. Dive trips, marine life encounters,
        the Fish ID series, gear and tips — all on YouTube.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        {
          socialLinks.map((s, i) =>
            i === 0 ? (
              <Button href={s.href} variant="light" external>{s.label}</Button>
            ) : (
              <Button href={s.href} variant="outline" external class="border-white text-white hover:bg-white hover:text-ocean-800">{s.label}</Button>
            )
          )
        }
      </div>
    </div>
  </section>

  <!-- What you'll find -->
  <section class="mx-auto max-w-6xl px-5 py-20">
    <h2 class="text-center text-2xl text-ocean-800 sm:text-3xl">What you'll find</h2>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        PILLARS.map((p) => (
          <a
            href={`/pillars/${p.slug}`}
            class="group rounded-2xl border border-ocean-100 bg-white p-6 transition-all hover:-translate-y-1 hover:shadow-lg"
          >
            <h3 class="text-xl text-ocean-800">{p.label}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{p.blurb}</p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
