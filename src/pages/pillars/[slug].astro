---
import { Image } from 'astro:assets';
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import VideoGrid from '../../components/VideoGrid.astro';
import ShowMore from '../../components/ShowMore.astro';
import Button from '../../components/Button.astro';
import { PILLARS } from '../../lib/nav';
import { SITE } from '../../lib/site';
import { pillarImages } from '../../lib/pillarImages';
import videoData from '../../content/videos/index.json';

export async function getStaticPaths() {
  return PILLARS.map((p) => ({ params: { slug: p.slug }, props: { pillar: p } }));
}

const { pillar } = Astro.props;
const entry = await getEntry('pillars', pillar.slug);
const { Content } = entry ? await render(entry) : { Content: null };
const heroImage = pillarImages[pillar.slug];

const posts = (await getCollection('journal', ({ data }) => !data.draft && data.pillar === pillar.slug))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pillarVideos = (videoData.items ?? []).filter((v) => v.pillar === pillar.slug);
const reelsOnly = pillarVideos.length > 0 && pillarVideos.every((v) => v.short);
const hasContent = pillarVideos.length > 0 || posts.length > 0;
---

<Layout
  title={pillar.label}
  description={`${pillar.label}, ${pillar.blurb} Part of Diving Diaries.`}
>
  <!-- Header hero -->
  <section class="relative flex min-h-[55vh] items-end overflow-hidden">
    {
      heroImage && (
        <Image
          src={heroImage}
          alt={pillar.label}
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          class="absolute inset-0 h-full w-full object-cover"
        />
      )
    }
    <div class="absolute inset-0 bg-gradient-to-t from-ocean-950/90 via-ocean-950/40 to-ocean-950/30"></div>
    <div class="relative mx-auto w-full max-w-4xl px-5 pb-14 text-white">
      <a href="/#pillars" class="text-sm font-semibold uppercase tracking-wide text-ocean-200 hover:text-white">
        ← All pillars
      </a>
      <h1 class="mt-4 text-4xl sm:text-6xl">{pillar.label}</h1>
      <p class="mt-4 max-w-2xl text-lg text-ocean-100">{pillar.blurb}</p>
    </div>
  </section>

  <!-- Long form content -->
  {
    Content && (
      <section class="mx-auto max-w-3xl px-5 pt-16">
        <div class="prose-dd space-y-5 text-lg leading-relaxed text-slate-700">
          <Content />
        </div>
      </section>
    )
  }

  <!-- Videos in this pillar -->
  {
    pillarVideos.length > 0 && (
      <section class="mx-auto max-w-6xl px-5 py-16">
        <p class="kicker">{reelsOnly ? 'Reels' : 'Watch'}</p>
        <h2 class="mt-3 text-3xl text-ocean-800">
          {pillarVideos.length} {reelsOnly ? 'reels' : 'videos'}
        </h2>
        <div class="mt-8">
          <ShowMore initial={15} label="Show all">
            <VideoGrid videos={pillarVideos} reels={reelsOnly} />
          </ShowMore>
        </div>
      </section>
    )
  }

  <!-- Journal posts in this pillar -->
  {
    posts.length > 0 && (
      <section class="mx-auto max-w-6xl px-5 pb-20">
        <p class="kicker">Read</p>
        <h2 class="mt-3 text-3xl text-ocean-800">From the journal</h2>
        <ShowMore initial={15} label="Show all posts">
          <div class="mt-8 grid gap-6 md:grid-cols-3">
            {posts.map((p) => (
              <PostCard
                slug={p.id}
                title={p.data.title}
                date={p.data.date}
                pillar={p.data.pillar}
                excerpt={p.data.excerpt}
                cover={p.data.cover}
              />
            ))}
          </div>
        </ShowMore>
      </section>
    )
  }

  <!-- Empty state (no videos and no posts yet) -->
  {
    !hasContent && (
      <section class="mx-auto max-w-6xl px-5 py-16">
        <div class="rounded-2xl border border-dashed border-ocean-200 bg-sand-50 p-10 text-center">
          <p class="text-slate-600">
            New {pillar.label.toLowerCase()} content is on the way. In the meantime,
            catch the latest on YouTube.
          </p>
          <div class="mt-5">
            <Button href={SITE.socials.youtube} external>Watch on YouTube</Button>
          </div>
        </div>
      </section>
    )
  }
</Layout>
